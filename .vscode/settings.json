{
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "editor.wordWrap": "on",
  "editor.rulers": [100],
  "markdown.extension.toc.levels": "2..6",
  "markdownlint.config": {
    "MD013": false,
    "MD033": false,
    "MD041": false
  },
  "[markdown]": {
    "editor.quickSuggestions": {
      "other": "on",
      "comments": "off",
      "strings": "off"
    }
  },
  "files.associations": {
    "CLAUDE.md": "markdown"
  }
}